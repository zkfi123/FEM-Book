"""
==============================================================================
  三维杆单元（空间桁架单元）刚度矩阵与应力计算程序
  课程作业：程序设计作业 —— 三维杆单元刚度矩阵与应力计算
  对应内容：2.2 单元刚度方程 Element Stiffness Equation

  单位约定：N, m, Pa
  仅使用 NumPy 进行基础矩阵运算，不调用任何有限元商业软件或现成有限元库
==============================================================================
"""

import numpy as np


# ==============================================================================
#  核心函数
# ==============================================================================

def truss3dElement_stiffness(x1, x2, E, A):
    """
    计算三维杆单元在全局坐标系下的单元刚度矩阵。

    根据课件推导：
        方向余弦  cx = x21/L,  cy = y21/L,  cz = z21/L
        刚度系数  k  = E*A/L
        Ke = k * [ c*c^T   -c*c^T ]
                 [ -c*c^T   c*c^T ]
    其中 c = [cx, cy, cz]^T

    Parameters
    ----------
    x1 : array_like
        节点1坐标 [x, y, z]，单位 m
    x2 : array_like
        节点2坐标 [x, y, z]，单位 m
    E : float
        弹性模量，单位 Pa
    A : float
        截面积，单位 m^2

    Returns
    -------
    L : float
        单元长度，单位 m
    direction_cosines : tuple
        方向余弦 (cx, cy, cz)
    Ke : ndarray, shape (6, 6)
        全局坐标系下的 6x6 单元刚度矩阵，单位 N/m
    """
    x1 = np.asarray(x1, dtype=np.float64)
    x2 = np.asarray(x2, dtype=np.float64)

    # 坐标增量 x21 = x2 - x1, y21 = y21 - y1, z21 = z2 - z1
    delta = x2 - x1

    # 单元长度
    L = np.linalg.norm(delta)

    # 退化单元检查：两节点重合
    if L < 1e-15:
        raise ValueError("错误：两个节点重合，单元长度为零，无法建立单元。")

    # 方向余弦
    cx, cy, cz = delta / L
    direction_cosines = (cx, cy, cz)

    # 刚度系数 k = EA / L
    k = E * A / L

    # 方向余弦向量
    c = np.array([cx, cy, cz])

    # 子块 cc^T (3x3)
    cc = np.outer(c, c)

    # 组装 6x6 刚度矩阵（分块形式）
    # [  cc   -cc ]
    # [ -cc    cc ]
    Ke = np.zeros((6, 6))
    Ke[0:3, 0:3] =  cc
    Ke[0:3, 3:6] = -cc
    Ke[3:6, 0:3] = -cc
    Ke[3:6, 3:6] =  cc
    Ke *= k

    return L, direction_cosines, Ke


def truss3dElement_stress(x1, x2, E, A, de):
    """
    根据单元节点位移计算三维杆单元的轴向应变、应力和轴力。

    根据课件推导：
        B^e = (1/L) * [-cx, -cy, -cz,  cx,  cy,  cz]   （应变-位移矩阵，1x6）
        epsilon = B^e * d^e                              （轴向应变）
        sigma   = E * epsilon                            （轴向应力，胡克定律）
        N       = A * sigma                              （轴力，受拉为正）

    Parameters
    ----------
    x1 : array_like
        节点1坐标 [x, y, z]，单位 m
    x2 : array_like
        节点2坐标 [x, y, z]，单位 m
    E : float
        弹性模量，单位 Pa
    A : float
        截面积，单位 m^2
    de : array_like
        单元节点位移 [u1, v1, w1, u2, v2, w2]，单位 m

    Returns
    -------
    epsilon : float
        轴向应变（无量纲）
    sigma : float
        轴向应力，单位 Pa
    N : float
        轴力，单位 N（受拉为正）
    """
    x1 = np.asarray(x1, dtype=np.float64)
    x2 = np.asarray(x2, dtype=np.float64)
    de = np.asarray(de, dtype=np.float64)

    delta = x2 - x1
    L = np.linalg.norm(delta)

    if L < 1e-15:
        raise ValueError("错误：两个节点重合，单元长度为零，无法计算。")

    # 方向余弦
    cx, cy, cz = delta / L

    # 应变-位移矩阵 B^e (1x6)
    Be = (1.0 / L) * np.array([-cx, -cy, -cz, cx, cy, cz])

    # 轴向应变
    epsilon = float(Be @ de)

    # 轴向应力
    sigma = E * epsilon

    # 轴力
    N = A * sigma

    return epsilon, sigma, N


# ==============================================================================
#  辅助检验函数
# ==============================================================================

def verify_symmetry(Ke):
    """检查刚度矩阵是否对称：Ke == Ke^T"""
    return np.allclose(Ke, Ke.T, atol=1e-8)


def verify_eigenvalues(Ke):
    """计算刚度矩阵的特征值（使用对称矩阵专用算法），检查是否非负"""
    eigenvalues = np.linalg.eigvalsh(Ke)
    all_nonneg = np.all(eigenvalues >= -1e-6 * np.max(np.abs(eigenvalues)))
    return eigenvalues, bool(all_nonneg)


def verify_rigid_body_translation(Ke, x1, x2, E, A):
    """
    检查刚体平移位移不产生内力。
    给所有节点施加相同的位移向量，应变为零，内力为零。
    """
    # 随机选择一个平移向量
    t = np.array([1.2e-3, -0.7e-3, 0.5e-3, 1.2e-3, -0.7e-3, 0.5e-3])
    epsilon, sigma, N = truss3dElement_stress(x1, x2, E, A, t)
    return epsilon, sigma, N


