def run_degenerate_check():
    """检查两节点重合时程序是否正确报错。"""
    print("\n")
    print("=" * 70)
    print("  退化单元检查")
    print("=" * 70)

    print("\n  测试：两节点重合 x1 = [0,0,0], x2 = [0,0,0]")
    try:
        truss3dElement_stiffness([0, 0, 0], [0, 0, 0], 200e9, 1e-4)
        print("  结果：未捕到错误（异常！）")
    except ValueError as e:
        print(f"  正确捕获错误: {e}")

    print("\n  测试：应变计算时两节点重合")
    try:
        truss3dElement_stress([0, 0, 0], [0, 0, 0], 200e9, 1e-4, [0, 0, 0, 1e-3, 0, 0])
        print("  结果：未捕到错误（异常！）")
    except ValueError as e:
        print(f"  正确捕获错误: {e}")


# ==============================================================================
#  工具函数
# ==============================================================================

def print_matrix(M, precision=4):
    """格式化打印矩阵"""
    n_rows, n_cols = M.shape
    for i in range(n_rows):
        row_str = "    ["
        for j in range(n_cols):
            val = M[i, j]
            if abs(val) < 1e-8:
                row_str += f"  {'0':>14s}"
            else:
                row_str += f"  {val:>14.{precision}f}"
        row_str += "  ]"
        print(row_str)


def check(description, passed):
    """打印检查结果"""
    mark = "PASS" if passed else "FAIL"
    print(f"  [{mark}]  {description}")


